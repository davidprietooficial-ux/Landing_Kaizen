# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
start-dev.command

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# MCP: contiene el token del Private Integration de GHL — NUNCA subir
.mcp.json

# llave SSH de diagnóstico contra el hosting de Hostinger — NUNCA subir
.claude/ssh/

# pnpm: el proyecto usa npm. Estos archivos hacen que el build (Hostinger/Vercel)
# detecte pnpm por error y rompa la consistencia (p.ej. el override de postcss).
/pnpm-lock.yaml
/pnpm-workspace.yaml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# originales pesados sin uso (se sirve la versión .jpg/.jpeg optimizada)
/public/img/team-1.png
/public/img/david-retrato.png
/public/img/agenda-popup.png
/public/img/agenda.png
/public/img/jennifer-retrato.jpeg
