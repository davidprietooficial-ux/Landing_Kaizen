{
  "name": "kaizen-cierre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Herramienta interna de cierre + cotizador en vivo de Kaizen Studios. Frontend estatico + /api/cierre (plugin de Vite en dev, funcion serverless en Vercel).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check-setup": "node scripts/check-setup.mjs",
    "deploy": "vercel deploy --prod --yes"
  },
  "dependencies": {
    "googleapis": "^173.0.0",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.8"
  }
}
