# ═════════════════════════════════════════════════════════════════════════════
#  Variables de entorno — Kaizen Cierre
#  Copia este archivo a `.env` y rellena los valores reales.
#  `.env` está en .gitignore → NUNCA se sube al repo.
# ═════════════════════════════════════════════════════════════════════════════

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ 1) CLIENTE (frontend Vite) — prefijo VITE_                                  │
# │    ⚠️ TODO lo que lleve VITE_ queda VISIBLE en el bundle del navegador.     │
# │    Pon aquí SOLO valores públicos (URLs, ids no secretos).                  │
# │    JAMÁS pongas una clave/secreto con prefijo VITE_.                        │
# └───────────────────────────────────────────────────────────────────────────┘

# URL del backend (serverless/VPS) al que el frontend manda el cierre.
VITE_API_BASE_URL=


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ 2) SERVIDOR (backend / serverless / VPS) — SIN prefijo VITE_                │
# │    Estos SÍ son secretos. Viven solo en el entorno del servidor             │
# │    (variables de entorno del VPS o de Vercel). NUNCA en el frontend.        │
# │    Se usan desde una función backend, no desde React.                       │
# └───────────────────────────────────────────────────────────────────────────┘

# ── Adobe Acrobat Sign (firma de la cotización) ──
ADOBE_SIGN_CLIENT_ID=
ADOBE_SIGN_CLIENT_SECRET=
ADOBE_SIGN_INTEGRATION_KEY=

# ── Google Sheets API (duplicar + llenar la plantilla de costeo) ──
# Usa una "service account". Pega el client_email y la private_key del JSON,
# o guarda el JSON como service-account.json (ya está en .gitignore).
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_TEMPLATE_ID=

# ── Envío de correo (cotización al cliente + presupuesto a David) ──
# Opción A — servicio (Resend / SendGrid / etc.):
EMAIL_API_KEY=
EMAIL_FROM=
# Opción B — SMTP propio:
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ── GoHighLevel (webhook entrante) ──
# Al cerrar, la calculadora hace POST de la cotización a este webhook. GHL encuentra
# al contacto por su email (ya existe en el CRM), actualiza su estado y dispara el
# workflow (seguimiento, recordatorios, etc.). OPCIONAL: si está vacío, el cierre
# funciona igual (correo + Sheets) y simplemente no toca el CRM.
# Cómo obtenerla: en GHL crea un Workflow → trigger "Inbound Webhook" → copia la URL.
GHL_WEBHOOK_URL=

# Nota: el login simple del sitio vive en el código (src/auth/Gate.tsx), no en
# variables de entorno — así viaja con la app a cualquier hosting (Hostinger, etc.).
